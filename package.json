{
  "name": "longterm-memory",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Context Engine plugin for long-term memory management",
  "main": "dist/index.js",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "cli": "tsx cli.ts"
  },
  "keywords": [
    "openclaw",
    "context-engine",
    "long-term-memory",
    "narrative-facts"
  ],
  "author": "zealot",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.55.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.31.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1"
  }
}
